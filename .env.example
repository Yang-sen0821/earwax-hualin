# ── 必填：複製此檔為 .env 並填入真實值 ──────────────────────────────────────
# .env 已加入 .gitignore，請勿 commit 真實密碼

# Flask session 加密金鑰（正式環境請改成隨機長字串）
SECRET_KEY=your-secret-key-change-me

# Supabase / PostgreSQL 連線字串
# 格式：postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ── init_db.py 種子帳號（首次建表後可刪除這幾行）────────────────────────────
# 老闆帳號（role=owner，可查看後台儀表板）
OWNER_USER=owner
OWNER_PASS=change-me-owner-pass

# 員工帳號（role=staff，只能做 4 步登錄與查庫存）
STAFF_USER=staff
STAFF_PASS=change-me-staff-pass
